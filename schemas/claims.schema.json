{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clyra.ai/schemas/claims.schema.json",
  "title": "Research Claims Ledger",
  "type": "object",
  "required": ["schema_version", "report_id", "claims"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "headline",
          "value",
          "artifact_path",
          "query"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "headline": {
            "type": "string",
            "minLength": 1
          },
          "value": {},
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
